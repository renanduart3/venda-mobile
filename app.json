{
  "expo": {
    "name": "Loja Inteligente — Vendas & Estoque",
    "slug": "venda-mobile",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "icon": "./assets/images/icon.png",
    "scheme": "lojaapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.renanduart3.vendamobile"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "react-native-iap",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.10"
          }
        }
      ],
      [
        "react-native-bootsplash",
        {
          "logo": "./assets/splash.png",
          "backgroundColor": "#4A90E2"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "BILLING"
      ],
      "package": "com.renanduart3.vendamobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/playstore-icon.png",
        "backgroundColor": "#4A90E2"
      },
      "navigationBar": {
        "backgroundColor": "#3b3b4c",
        "barStyle": "light-content"
      },
      "statusBar": {
        "backgroundColor": "#3b3b4c",
        "barStyle": "light-content",
        "translucent": false
      }
    }
  }
}