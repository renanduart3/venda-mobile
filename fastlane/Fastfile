require 'json'
require 'fileutils'
require 'socket'
require 'resolv'

# Force IPv4 - Ruby 3.4 on Windows tries IPv6 first, causing 2min timeouts
# Patches TCPSocket directly since Faraday/Net::HTTP bypass Socket.getaddrinfo
module ForceIPv4Connection
  def initialize(host, port, *args)
    begin
      addrs = Resolv::DNS.new.getaddresses(host)
      ipv4 = addrs.find { |a| a.is_a?(Resolv::IPv4) }&.to_s
      host = ipv4 if ipv4
    rescue StandardError
      # keep original host on error
    end
    super(host, port, *args)
  end
end
TCPSocket.prepend(ForceIPv4Connection)

default_platform(:android)

platform :android do
  desc "Increment versionCode and versionName in app.json and build.gradle"
  private_lane :bump_version do
    app_json_path = File.expand_path('../../app.json', __FILE__)
    app_json = JSON.parse(File.read(app_json_path))

    current_code = app_json["expo"]["android"]["versionCode"].to_i
    new_code = current_code + 1
    new_name = "1.0.#{new_code}"

    app_json["expo"]["version"] = new_name
    app_json["expo"]["android"]["versionCode"] = new_code
    File.write(app_json_path, JSON.pretty_generate(app_json) + "\n")

    gradle_path = File.expand_path('../../android/app/build.gradle', __FILE__)
    gradle_content = File.read(gradle_path)
    gradle_content = gradle_content.gsub(/versionCode \d+/, "versionCode #{new_code}")
    gradle_content = gradle_content.gsub(/versionName "[\d.]+"/, "versionName \"#{new_name}\"")
    File.write(gradle_path, gradle_content)

    UI.success "✅ Versão atualizada para #{new_name} (versionCode: #{new_code})"
  end

  desc "Remove stale CMake cache to prevent native build errors"
  private_lane :clean_cmake_cache do
    paths_to_clean = [
      File.expand_path('../../android/app/.cxx', __FILE__),
      File.expand_path('../../android/.cxx', __FILE__),
      File.expand_path('../../node_modules/react-native-iap/android/.cxx', __FILE__),
      'C:/cx/iap/react-native-iap'
    ]

    paths_to_clean.each do |path|
      next unless Dir.exist?(path)

      FileUtils.rm_rf(path)
      UI.success "🧹 Cache CMake removido: #{path}"
    end
  end

  desc "Send an internal test build to Google Play"
  lane :internal_test do
    bump_version
    clean_cmake_cache
    gradle(task: "bundleRelease", project_dir: "android/")
    upload_to_play_store(
      track: 'internal',
      release_status: 'draft',
      skip_upload_apk: true
    )
  end

  desc "Deploy a new version to the Google Play"
  lane :deploy_production do
    bump_version
    clean_cmake_cache
    gradle(task: "bundleRelease", project_dir: "android/")
    upload_to_play_store(
      track: 'production',
      skip_upload_apk: true
    )
  end
end
